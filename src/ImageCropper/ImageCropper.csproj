<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PackageId>ImageCropper</PackageId>
    <Version>0.1.0</Version>
    <Authors>agriffard</Authors>
    <Company>agriffard</Company>
    <Description>Blazor ImageCropper component for crop/rotate/zoom with aspect-ratio lock and blob export.</Description>
    <PackageTags>blazor;image;cropper;upload;avatar</PackageTags>
    <PackageProjectUrl>https://github.com/agriffard/ImageCropper</PackageProjectUrl>
    <RepositoryUrl>https://github.com/agriffard/ImageCropper</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>PACKAGE.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="10.0.8" />
  </ItemGroup>

  <ItemGroup>
    <None Include="PACKAGE.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
